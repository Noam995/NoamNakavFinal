<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_admin"
    tools:context=".MainActivity">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="יצירת משתמש חדש"
                android:textAlignment="center"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:layout_marginBottom="24dp"/>

            <EditText
                android:id="@+id/etFname"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:hint="שם פרטי"
                android:background="@drawable/bg_input"
                android:paddingStart="16dp"
                android:layout_marginBottom="12dp"/>

            <EditText
                android:id="@+id/etLname"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:hint="שם משפחה"
                android:background="@drawable/bg_input"
                android:paddingStart="16dp"
                android:layout_marginBottom="12dp"/>

            <EditText
                android:id="@+id/etemail"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:hint="אימייל"
                android:inputType="textEmailAddress"
                android:background="@drawable/bg_input"
                android:paddingStart="16dp"
                android:layout_marginBottom="12dp"/>

            <EditText
                android:id="@+id/etphone"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:hint="מספר טלפון"
                android:inputType="phone"
                android:background="@drawable/bg_input"
                android:paddingStart="16dp"
                android:layout_marginBottom="12dp"/>

            <EditText
                android:id="@+id/etpassword"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:hint="סיסמה"
                android:inputType="textPassword"
                android:background="@drawable/bg_input"
                android:paddingStart="16dp"
                android:layout_marginBottom="24dp"/>

            <Button
                android:id="@+id/btnSubmit"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="הירשם והתחבר"
                android:backgroundTint="@color/black"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                app:cornerRadius="10dp"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:id="@+id/tvLogin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="כבר יש לך חשבון? התחבר כאן"
                android:textAlignment="center"
                android:textColor="@color/black"
                android:textStyle="italic"
                android:padding="8dp"/>

            <Button
                android:id="@+id/btnBackToMain"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:textSize="10sp"
                android:text="חזרה למסך הראשי"
                android:textColor="#1F3A5F"
                app:strokeColor="#1F3A5F"
                android:onClick="main"
                android:layout_marginHorizontal="40dp"
                android:layout_marginBottom="24dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>