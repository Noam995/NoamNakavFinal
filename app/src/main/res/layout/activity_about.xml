<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_about"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#1F3A5F"
            app:title="אודות Noam Motors"
            app:titleTextColor="#FFFFFF"
            app:titleCentered="true"/>
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <ImageView
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:src="@drawable/logo"
                android:padding="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Noam Motors"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#1F3A5F"
                android:layout_marginTop="10dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="האפליקציה פותחה כמערכת מתקדמת לניהול ורכישת רכבים, המאפשרת חוויה מהירה, בטוחה ומקצועית."
                android:textSize="16sp"
                android:textColor="#444444"
                android:layout_marginTop="15dp"
                android:gravity="center"/>

            <Button
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="נווט לסוכנות שלנו 🗺️"
                android:backgroundTint="#3A6EA5"
                android:textColor="#FFFFFF"
                android:layout_marginTop="30dp"
                android:onClick="navigateToDealership"/>

            <Button
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="חזרה למסך הראשי"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:textColor="#1F3A5F"
                app:strokeColor="#1F3A5F"
                android:layout_marginTop="10dp"
                android:onClick="main"/>

        </LinearLayout>
    </ScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>